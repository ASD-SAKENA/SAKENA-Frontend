NODE_ENV=development
# Client-side API base. Baked into the bundle at BUILD time (see Dockerfile
# build-args). In CI this comes from the `NEXT_PUBLIC_API_BASE` repo variable.
NEXT_PUBLIC_API_BASE=http://localhost:8080/api/v1
# Server-side requests (RSC) reach the backend container over the Docker network.
INTERNAL_API_BASE=http://localhost:8080/api/v1
NEXT_PUBLIC_CURRENT_URL=http://localhost:3000

